// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "vim": {
    "custom_digraphs": {
      "g d": "GoToDefintiion",
    },
    "use_system_clipboard": "always",
    "toggle_relative_line_numbers": true,
  },
  "agent_servers": {
    "cursor": {
      "type": "registry",
    },
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "proxy": "",
  "language_models": {
    "openai": {
      "available_models": [
        {
          "name": "gpt-5.4-mini",
          "display_name": "gpt-5.4-mini xhigh",
          "reasoning_effort": "high",
          "max_tokens": 400000,
          "max_completion_tokens": 128000,
          "capabilities": {
            "chat_completions": false,
          },
        },
      ],
    },
  },
  "icon_theme": {
    "mode": "light",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "agent": {
    "dock": "right",
    "enable_feedback": false,
    "tool_permissions": {
      "default": "allow",
      "tools": {
        "terminal": {
          "default": "allow",
        },
      },
    },
    "default_model": {
      "enable_thinking": false,
      "provider": "openai",
      "model": "gpt-5.4",
    },
    "favorite_models": [
      {
        "provider": "openai",
        "model": "gpt-5.4",
        "enable_thinking": false,
      },
      {
        "provider": "openai",
        "model": "gpt-5.4-mini",
        "enable_thinking": true,
      },
    ],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true,
  },
  "ssh_connections": [
    {
      "host": "coder.fergus-bao",
      "args": [],
      "projects": [
        {
          "paths": ["/home/coder/work/canva/web"],
        },
      ],
    },
    {
      "host": "coder.fergus-custard",
      "args": [],
      "projects": [
        {
          "paths": ["/home/coder/work/canva/web"],
        },
      ],
    },
  ],
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "multi_cursor_modifier": "cmd_or_ctrl",
  "minimap": {
    "show": "never",
  },
  "cursor_shape": "bar",
  "restore_on_file_reopen": false,
  "autosave": "on_focus_change",
  "buffer_font_fallbacks": ["Menlo", "Monaco", "Courier New"],
  "file_types": {
    "haskell": ["*.hs"],
  },
  "linked_edits": true,
  "show_whitespaces": "none",
  "ensure_final_newline_on_save": true,
  "wrap_guides": [100],
  "preferred_line_length": 90,
  "soft_wrap": "editor_width",
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 11.0,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Zedokai Darker (Filter Spectrum)",
  },
}
